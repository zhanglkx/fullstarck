# ===== API =====
API_PORT=3000
API_BASE_URL=http://localhost:3000

# ===== Web =====
WEB_PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3000

# ===== Mobile =====
EXPO_PUBLIC_API_URL=http://localhost:3000

# ===== PostgreSQL =====
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=fullstack
POSTGRES_PORT=5432
# 应用内使用的连接串（Docker 内部通过服务名 postgres 连接）
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fullstack

# ===== Redis =====
REDIS_PASSWORD=redis
REDIS_PORT=6379
REDIS_URL=redis://default:redis@localhost:6379

# ===== pgAdmin（docker compose --profile tools up 时生效） =====
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050
