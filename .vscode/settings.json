{
  // Prettier as default formatter
  "editor.defaultFormatter": "esbenp.prettier-vscode",

  // Enable format on save
  "editor.formatOnSave": true,

  // Format on paste
  "editor.formatOnPaste": true,

  // Format on type
  "editor.formatOnType": false,

  // Enable auto-fix on save for ESLint
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },

  // File associations
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[less]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[scss]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },

  // ESLint settings
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],

  // TypeScript settings
  "typescript.tsdk": "node_modules/typescript/lib",
  "typescript.enablePromptUseWorkspaceTsdk": true,

  // Files to exclude from explorer
  "files.exclude": {
    "**/.git": true,
    "**/.DS_Store": true,
    "**/node_modules": true,
    "**/.next": true,
    "**/next.config.ts": true,
    "**/pnpm-workspace.yaml": true,
    "**/pnpm-lock.yaml": true,
    "**/eslint.config.mjs": true,
    "**/.eslintignore": true,
    "**/AGENTS.md": true,
    "**/.gitignore": true,
    "**/CLAUDE.md": true,
    "**/.npmrc": true,
    "**/.prettierrc": true,
    "**/.idea": true,
    "**/.sisyphus": true,
    "**/.claude": true,
    "**/apps/mobile/.expo": true,
    "**/.prettierignore": true,
    "apps/web/next-env.d.ts": true,
    "apps/web/tsconfig.json": true,
    "apps/web/tsconfig.tsbuildinfo": true,
    "apps/api/tsconfig.json": true,
    "apps/api/tsconfig.tsbuildinfo": true,
    "apps/api/tsconfig.build.json": true,
    "**/dist": true
  },

  // Search exclude
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/.next": true,
    "**/pnpm-lock.yaml": true
  }
}
