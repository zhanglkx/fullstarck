{
  "name": "fullstack-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter './apps/*' dev",
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "dev:mobile": "pnpm --filter mobile start",
    "build": "pnpm --filter './apps/*' build",
    "build:api": "pnpm --filter api build",
    "build:web": "pnpm --filter web build",
    "build:mobile": "pnpm --filter mobile build",
    "lint": "pnpm --parallel --filter './apps/*' --filter './packages/*' lint",
    "lint:root": "eslint .",
    "test": "pnpm --filter './apps/*' test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,less,scss,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,less,scss,md}\"",
    "clean": "pnpm --filter './apps/*' clean && rm -rf node_modules",
    "clean:cache": "rm -rf node_modules/.cache && pnpm store prune",
    "generate:api": "pnpm --filter api generate",
    "g:api": "pnpm --filter api g",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:up:infra": "docker compose up -d postgres redis",
    "docker:up:tools": "docker compose --profile tools up -d",
    "docker:down": "docker compose down",
    "docker:down:volumes": "docker compose down -v",
    "docker:logs": "docker compose logs -f",
    "docker:ps": "docker compose ps",
    "docker:restart": "docker compose restart"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "eslint": "^9.18.0",
    "globals": "^17.4.0",
    "prettier": "^3.4.2",
    "typescript-eslint": "^8.20.0"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.33.0"
}
